#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'pathname'
require_relative '../scripts/eval_context_builder'

# bin/eval-context <scenario-path>
# Example: bin/eval-context personal-evals/code-review

scenario_path = ARGV[0]

if scenario_path.nil? || scenario_path.empty?
  warn "Usage: bin/eval-context <scenario-path>"
  exit 1
end

scenario_dir = Pathname.new(scenario_path)
metadata_file = scenario_dir.join('metadata.json')

unless metadata_file.exist?
  warn "Error: metadata.json not found in #{scenario_path}"
  exit 1
end

begin
  metadata = JSON.parse(metadata_file.read)
  target_type = metadata['target_type'] # 'skill' or 'workflow'
  target_name = metadata['target_name']

  unless target_type && target_name
    warn "Error: metadata.json must contain 'target_type' and 'target_name'"
    exit 1
  end

  project_root = Pathname.new(__dir__).join('..').realpath
  
  target_skill_path = if target_type == 'skill'
    # Find skill in any category
    Pathname.glob(project_root.join('skills', '**', target_name, 'SKILL.md')).first
  else
    project_root.join('workflows', target_name, 'SKILL.md')
  end

  unless target_skill_path&.exist?
    warn "Error: Could not find SKILL.md for #{target_type} '#{target_name}'"
    exit 1
  end

  # Build the XML context
  xml_context = McpSkills::EvalContextBuilder.call(target_skill_path.dirname)
  puts xml_context

rescue JSON::ParserError => e
  warn "Error parsing metadata.json: #{e.message}"
  exit 1
rescue StandardError => e
  warn "Error: #{e.message}"
  exit 1
end
