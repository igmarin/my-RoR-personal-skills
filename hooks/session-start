#!/usr/bin/env bash
# SessionStart hook for rails-agent-skills

set -euo pipefail

session_context="<IMPORTANT>\nYou have access to Rails Agent Skills via MCP.\nUse the 'use_skill' MCP tool to dynamically load the skill you need.\nReview docs/reference/skill-catalog.md for the full list of available skills.\n</IMPORTANT>"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
