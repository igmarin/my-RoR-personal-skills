evals/
private-evals/
tmp/
.lean-ctx/
lean-ctx/
.Gemfile.lock
.Gemfile

# IDE / AI assistant configs (personal, not shared)
.crush/
.codex/
.codex-plugin/
.gemini/
.gemini-plugin/
.cursor/
.windsurf/
# Personal and internal files (Hidden from Tessl)
personal-evals/
skills/**/README.md
workflows/README.md
CHANGELOG.md
docs/eval-provenance.md
docs/evaluator-and-agents-roadmap.md

.tessl/
.ruby-lsp/
.vscode/

