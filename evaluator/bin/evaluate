#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'
require 'json'
require_relative '../lib/runner'
require_relative '../lib/evaluator/history_recorder'

options = {}
OptionParser.new do |opts|
  opts.banner = 'Usage: evaluate [options]'

  opts.on('-e', '--eval FOLDER',
          'Path to the eval folder (e.g., evals/skills/infrastructure/rails-api-versioning/api-versioning...)') do |e|
    options[:eval] = e
  end

  opts.on('-s', '--skill FOLDER',
          'Path to the skill folder to hydrate from (e.g., skills/infrastructure/rails-api-versioning)') do |s|
    options[:skill] = s
  end

  opts.on('-o', '--output FILE', 'Path to save the JSON report') do |o|
    options[:output] = o
  end
end.parse!

if options[:eval].nil? || options[:skill].nil?
  puts 'Error: Both --eval and --skill options are required.'
  puts 'Example: bin/evaluate -e evals/skills/infrastructure/rails-api-versioning/api-versioning-with-controller-inheritan -s skills/infrastructure/rails-api-versioning'
  exit 1
end

result = Evaluator::Runner.call(
  eval_folder_path: options[:eval],
  skill_path: options[:skill]
)

puts "\n========================================="
puts '              RESULTS                    '
puts "=========================================\n"

unless result[:success]
  puts "Evaluation failed: #{result[:response][:error][:message]}"
  exit 1
end

result[:tasks].each do |task_result|
  puts "\n========================================="
  puts "       RESULTS: #{task_result[:path]}    "
  puts "=========================================\n"

  begin
    parsed_judge = JSON.parse(task_result[:judge_score])
    puts "Baseline Score: #{parsed_judge['baseline_score']}/100"
    puts "Context Score:  #{parsed_judge['context_score']}/100"
    puts "\nReasoning:"
    puts parsed_judge['reasoning']

    puts "\n========================================="
    puts "  BASELINE CHANGES: #{task_result[:path]}  "
    puts "=========================================\n"
    puts task_result[:baseline_diff]

    puts "\n========================================="
    puts "   CONTEXT CHANGES: #{task_result[:path]}  "
    puts "=========================================\n"
    puts task_result[:context_diff]
  rescue JSON::ParserError
    puts 'Could not parse judge JSON response. Raw output:'
    puts task_result[:judge_score]
  end
end

if options[:output]
  File.write(options[:output], JSON.pretty_generate(result))
  puts "\nReport saved to #{options[:output]}"
end

Evaluator::HistoryRecorder.record(
  result,
  skill_path: options[:skill],
  model: Evaluator::Config.model
)
